# Supabase (https://supabase.com/dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# CricAPI free tier key (https://cricketdata.org)
CRICAPI_KEY=your-cricapi-key

# Cache TTL for live score responses (seconds)
CRICKET_CACHE_TTL=60

# Cricket news comes from ESPNcricinfo RSS — no API key required.
# This only controls how long fetched news is cached in memory (seconds).
NEWS_CACHE_TTL=300

# Resend email service (https://resend.com)
# Used for login confirmation emails when user logs in from new device
RESEND_API_KEY=your-resend-api-key
